# Copy to .env and fill in. Never commit the real .env.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=tracetrail
MYSQL_USER=tt
MYSQL_PASSWORD=change-me-app
TRACETRAIL_RETENTION_DAYS=7
INGESTION_RATE_LIMIT_CAPACITY=200
INGESTION_RATE_LIMIT_REFILL_PER_SEC=50
QUERY_CACHE_TTL_SECONDS=30
DEMO_TRAFFIC_RPS=5
DEMO_TENANT_KEY=11111111-1111-1111-1111-111111111111
TEST_TENANT_KEY=22222222-2222-2222-2222-222222222222

# Origins allowed to call the Query Service from a browser (frontend).
# Defaults already cover the Vite dev/preview ports; override for prod hosting.
# TRACETRAIL_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
